<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pato Master - Iniciar Sesión</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    
    <style>
        * { box-sizing: border-box; font-family: 'Roboto', sans-serif; }

        body {
            background-color: #000;
            /* Fondo con imagen de restaurante oscuro */
            background-image: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('/images/background-pattern.jpg');
            background-size: cover;
            background-position: center;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .registro-container {
            background-color: rgba(26, 26, 26, 0.95); /* Gris casi negro */
            border: 2px solid #d32f2f; /* Rojo "Pato" */
            border-radius: 15px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 0 25px rgba(211, 47, 47, 0.3);
            text-align: center;
        }

        .registro-container img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 1px solid #d32f2f;
            margin-bottom: 15px;
            transition: 0.3s;
        }

        .registro-container img:hover {
            transform: scale(1.05);
        }

        h2 {
            color: white;
            font-family: 'Bebas Neue', cursive;
            font-size: 2.5rem;
            letter-spacing: 2px;
            margin-bottom: 25px;
            text-transform: uppercase;
        }

        label {
            display: block;
            text-align: left;
            color: #aaa;
            margin-top: 15px;
            font-size: 0.85rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 12px;
            margin-top: 5px;
            background-color: #1a1a1a;
            border: 1px solid #333;
            border-radius: 8px;
            color: white;
            outline: none;
            transition: 0.3s;
        }

        input:focus {
            border-color: #d32f2f;
            box-shadow: 0 0 8px rgba(211, 47, 47, 0.4);
        }

        button[type="submit"] {
            width: 100%;
            background-color: #d32f2f;
            color: white;
            padding: 15px;
            margin-top: 30px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Bebas Neue', cursive;
            font-size: 1.5rem;
            letter-spacing: 1px;
            transition: 0.3s;
        }

        button[type="submit"]:hover {
            background-color: #b71c1c;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(211, 47, 47, 0.4);
        }

        .login-link {
            margin-top: 25px;
            font-size: 0.9rem;
        }

        .login-link p { color: #888; }

        .login-link a {
            color: #d32f2f;
            text-decoration: none;
            font-weight: bold;
        }

        .login-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="registro-container">
        <a href="/">
							<img src="../images/icons/logo.png" alt="IMG-LOGO" data-logofixed="images/icons/logo2.png" width="10px" height="10px">
						</a>
        
        <h2>Iniciar Sesión</h2>

        <form action="/login" method="POST">
            <label>Nombre de usuario</label>
            <input type="text" name="nombre" placeholder="Tu usuario" required>

            <label>Contraseña</label>
            <input type="password" name="clave" placeholder="••••••••" required>

            <button type="submit">INGRESAR AL SISTEMA</button>
        </form>

        <div class="login-link">
            <p>¿No tienes cuenta todavía? <a href="/register">Regístrate aquí</a></p>
        </div>
    </div>

</body>
</html>